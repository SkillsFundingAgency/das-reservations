@model DeleteViewModel
@{
    ViewData["Title"] = "Reservations";
    ViewBag.GaData.Vpv = "/reservations/delete";
}

<a asp-route="@RouteNames.ProviderManage" class="govuk-back-link" asp-route="@RouteNames.ProviderManage" asp-route-ukprn="@Model.UkPrn">Back</a>

<main class="govuk-main-wrapper " id="main-content" role="main">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">

            <partial name="_PageErrorsOverview"/>

            <h1 class="govuk-heading-xl">Are you sure you want to delete this reservation?</h1>

            <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <div class="govuk-warning-text__text">
                    <span class="govuk-warning-text__assistive">You cannot undo this action.</span>
                </div>
            </div>
            <div class="govuk-summary-list">
                <dl class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Employer
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.AccountLegalEntityName
                    </dd>
                </dl>
                <dl class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Start date
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.StartDateDescription
                    </dd>
                </dl>
                <dl class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Training course
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.CourseDescription
                    </dd>
                </dl>
                <dl class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Training type
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.LearningType
                    </dd>
                </dl>
            </div>

            <form method="post" asp-route="@RouteNames.ProviderDelete" asp-route-id="@Model.Id" asp-route-ukprn="@Model.UkPrn">
                <input type="hidden" id="AccountLegalEntityName" name="AccountLegalEntityName" value="@Model.AccountLegalEntityName"/>
                <input type="hidden" id="StartDateDescription" name="StartDateDescription" value="@Model.StartDateDescription"/>
                <input type="hidden" id="CourseDescription" name="CourseDescription" value="@Model.CourseDescription"/>               

                <div>
                <button type="submit" draggable="false" class="govuk-button govuk-button--warning">
                    Yes, I'm sure
                </button>
                </div>

                <a class="govuk-link govuk-link--no-visited-state govuk-!-margin-top-2 govuk-!-font-size-19" style="display:inline-block" asp-route="@RouteNames.ProviderManage" asp-route-ukprn="@Model.UkPrn">No, go back to manage reservations</a>
            </form>
        </div>
    </div>
</main>